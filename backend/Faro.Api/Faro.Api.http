@baseUrl = https://localhost:7270

### Health check
GET {{baseUrl}}/

### Get all venues
GET {{baseUrl}}/api/venues

### Create venue
POST {{baseUrl}}/api/venues
Content-Type: application/json

{
  "name": "Test Venue",
  "addressLine1": "123 Main Street",
  "addressLine2": null,
  "city": "Santo Domingo",
  "state": "Distrito Nacional",
  "postalCode": null,
  "country": "Dominican Republic",
  "latitude": 18.4861,
  "longitude": -69.9312,
  "placeId": null,
  "venueType": "Indoor",
  "capacity": 100,
  "isRentable": true,
  "rentalNotes": "Available for small community events.",
  "isPubliclyListed": true
}

### Get all events
GET {{baseUrl}}/api/events

### Create event
POST {{baseUrl}}/api/events
Content-Type: application/json

{
  "title": "Test Faro Event",
  "description": "First test event using a real venue from SQL Server.",
  "startAtUtc": "2026-06-10T23:00:00Z",
  "endAtUtc": "2026-06-11T01:00:00Z",
  "isFree": true,
  "priceAmount": null,
  "priceLabel": "Free",
  "category": "Community",
  "imageUrl": null,
  "externalUrl": null,
  "venueId": "0381ed1e-7e4a-4aa7-97af-50e2a621f262"
}

@baseUrl = https://localhost:7270

### Create user account
POST {{baseUrl}}/api/user-accounts
Content-Type: application/json

{
  "email": "diego@test.com",
  "displayName": "Diego Test"
}

### Get user account by id
GET {{baseUrl}}/api/user-accounts/0F945146-18D9-408B-BEF8-68ECE1426E23

### Create business
POST {{baseUrl}}/api/businesses
Content-Type: application/json

{
  "name": "Diego Events",
  "description": "Test business account for event hosting.",
  "businessType": "Event Host",
  "venueRelationship": 2,
  "ownerUserAccountId": "0F945146-18D9-408B-BEF8-68ECE1426E23"
}

### Get business by id
GET {{baseUrl}}/api/businesses/fbd7dae0-3e47-4c92-8020-d8d2ee1ec2dc

### Get businesses for user
GET {{baseUrl}}/api/user-accounts/0F945146-18D9-408B-BEF8-68ECE1426E23/businesses

### Create business-owned event
POST {{baseUrl}}/api/events
Content-Type: application/json

{
  "title": "Business-Owned Test Event",
